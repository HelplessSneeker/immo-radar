# Kopie als .env ablegen – der Server lädt sie beim Start.
DATABASE_URL=postgres://immo:immo@localhost:5432/immo

# Basic-Auth vor allen Seiten (außer /health). Ohne diese beiden Vars
# startet der Server nicht – für Prod ein langes Secret wählen.
BASIC_AUTH_USER=immo
BASIC_AUTH_PASS=aendere-mich

# Optional, Default 8787.
# PORT=8787
