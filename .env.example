# Kopie als .env ablegen – der Server lädt sie beim Start.
DATABASE_URL=postgres://immo:immo@localhost:5432/immo

# Ein-Benutzer-Zugang. Anmeldung läuft über /login (Session-Cookie), nicht
# mehr als Browser-Basic-Auth-Popup. Ohne diese beiden Vars startet der Server
# nicht – für Prod ein langes Passwort wählen.
BASIC_AUTH_USER=immo
BASIC_AUTH_PASS=aendere-mich

# Geheimnis für das Session-Cookie (HMAC-SHA256). Mindestens 32 Zeichen,
# ausreichend Zufall. Rotation invalidiert alle bestehenden Sitzungen.
# Erzeugen z.B. mit: `openssl rand -hex 32`
SESSION_SECRET=aendere-mich-mindestens-32-zeichen-zufall

# Optional, Default 8787.
# PORT=8787

# Optional: Scheduler-Tick in ms, Default 30 Minuten.
# CRAWL_TICK_MS=1800000

# Optional: Pause zwischen Sweep-Segmenten in ms, Default 15 Sekunden.
# SWEEP_SEGMENT_PAUSE_MS=15000
