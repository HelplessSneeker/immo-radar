{
  "name": "immo-radar",
  "version": "1.5.0",
  "description": "Immobilienmarkt-Analyse für Anlageobjekte in Kärnten: täglicher Sweep, Objekt-Dedup, Zeitreihen-Dashboard, Portfolio",
  "type": "module",
  "bin": {
    "immo-radar": "./bin/immo-radar.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "analyze": "tsx src/cli.ts analyze",
    "serve": "tsx src/server.ts",
    "db:up": "docker compose up -d",
    "db:migrate": "tsx src/db/migrate-cli.ts",
    "objekte:rebuild": "tsx src/db/objekte-rebuild-cli.ts",
    "plausibilitaet:rebuild": "tsx src/db/plausibilitaet-rebuild-cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.13.0+sha512.88d94724d8f2e6c186744a5584c6e59ecac869ec7ba15e9cb4cd628e8dc7066820b2481d8ee3b51ea8da323a7378068aa58c556a3720d32b7c20a051d088363a",
  "devDependencies": {
    "@types/node": "^22.20.1",
    "@types/pg": "^8.20.0",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "pg": "^8.22.0"
  }
}
