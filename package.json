{
  "name": "immo-radar",
  "version": "0.1.0",
  "description": "Immobilienmarkt-Analyse für Anlageobjekte in Österreich (V1: CSV/JSON-Import, statischer HTML-Report)",
  "type": "module",
  "bin": {
    "immo-radar": "./bin/immo-radar.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "analyze": "tsx src/cli.ts analyze",
    "serve": "tsx src/server.ts",
    "db:up": "docker compose up -d",
    "db:migrate": "tsx src/db/migrate-cli.ts",
    "objekte:rebuild": "tsx src/db/objekte-rebuild-cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.1.1",
  "devDependencies": {
    "@types/node": "^22.20.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "pg": "^8.22.0"
  }
}
